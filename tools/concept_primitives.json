        },
        {
          "name": "pid_controller",
          "abstraction": "three_term_regulator",
          "relations": [
            {"type": "implements", "target": "feedback_loop"},
            {"type": "combines", "target": "proportional_control_with_integral_and_derivative"},
            {"type": "minimizes", "target": "tracking_error"}
          ]
        },
        {
          "name": "model_predictive_control",
          "abstraction": "lookahead_optimizer",
          "relations": [
            {"type": "replaces", "target": "reactive_feedback"},
            {"type": "requires", "target": "system_model"},
            {"type": "optimizes", "target": "future_trajectory"}
