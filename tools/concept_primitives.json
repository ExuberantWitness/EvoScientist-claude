{
  "meta": {
    "description": "Concept primitive library for Structure Mapping Engine. Each domain is a relational graph of concepts — SME compares graph structures, not entity names.",
    "version": "1.0",
    "total_domains": 8
  },
  "domains": {
    "evolutionary_algorithms": {
      "name": "Evolutionary Algorithms",
      "description": "Population-based optimization through variation, selection, and inheritance",
      "concepts": [
        {
          "name": "mutation",
          "abstraction": "random_variation",
          "relations": [
            {"type": "generates", "target": "diversity"},
            {"type": "precedes", "target": "selection"},
            {"type": "operates_on", "target": "population"}
          ]
        },
        {
          "name": "selection",
          "abstraction": "fitness_filter",
          "relations": [
            {"type": "precedes", "target": "inheritance"},
            {"type": "evaluates", "target": "fitness"},
            {"type": "operates_on", "target": "population"}
          ]
        },
        {
          "name": "inheritance",
          "abstraction": "trait_preservation",
          "relations": [
            {"type": "precedes", "target": "mutation"},
            {"type": "preserves", "target": "fitness"},
            {"type": "operates_on", "target": "population"}
          ]
        },
        {
          "name": "fitness",
          "abstraction": "quality_metric",
          "relations": [
            {"type": "guides", "target": "selection"},
            {"type": "constrains", "target": "exploration"}
          ]
        }
      ],
      "signature_cycles": [
        {"name": "variation_selection_loop", "pattern": ["mutation", "selection", "inheritance"], "relation_chain": "precedes→precedes→precedes", "type": "cyclic_3node"},
        {"name": "fitness_driven_filter", "pattern": ["fitness", "selection"], "relation_chain": "guides", "type": "control"}
      ]
    },

