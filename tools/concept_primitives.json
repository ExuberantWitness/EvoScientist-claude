            {"type": "precedes", "target": "performance_evaluation"},
            {"type": "operates_on", "target": "search_space"}
          ]
        },
        {
          "name": "performance_evaluation",
          "abstraction": "fitness_filter",
          "relations": [
            {"type": "precedes", "target": "weight_inheritance"},
            {"type": "evaluates", "target": "validation_accuracy"},
            {"type": "operates_on", "target": "search_space"}
          ]
        },
        {
          "name": "weight_inheritance",
          "abstraction": "trait_preservation",
          "relations": [
            {"type": "precedes", "target": "architecture_generation"},
            {"type": "preserves", "target": "validation_accuracy"},
            {"type": "operates_on", "target": "search_space"}
          ]
        },
        {
          "name": "validation_accuracy",
          "abstraction": "quality_metric",
          "relations": [
            {"type": "guides", "target": "performance_evaluation"},
            {"type": "constrains", "target": "architecture_diversity"}
          ]
        }
      ],
      "signature_cycles": [
        {"name": "generate_evaluate_loop", "pattern": ["architecture_generation", "performance_evaluation", "weight_inheritance"], "relation_chain": "precedes→precedes→precedes", "type": "cyclic_3node"},
        {"name": "accuracy_driven_filter", "pattern": ["validation_accuracy", "performance_evaluation"], "relation_chain": "guides", "type": "control"}
      ]
    },

    "reinforcement_learning": {
      "name": "Reinforcement Learning",
      "description": "Learning through interaction: exploration, exploitation, policy improvement",
      "concepts": [
        {
          "name": "exploration",
          "abstraction": "random_variation",
          "relations": [
            {"type": "collects", "target": "experience"},
            {"type": "precedes", "target": "exploitation"},
            {"type": "requires", "target": "stochastic_policy"}
          ]
        },
        {
          "name": "exploitation",
          "abstraction": "fitness_filter",
          "relations": [
            {"type": "consumes", "target": "experience"},
            {"type": "precedes", "target": "policy_improvement"},
            {"type": "maximizes", "target": "expected_return"}
          ]
        },
        {
          "name": "policy_improvement",
          "abstraction": "trait_preservation",
          "relations": [
            {"type": "updates", "target": "policy"},
            {"type": "precedes", "target": "policy_evaluation"},
            {"type": "uses", "target": "experience"}
          ]
        },
        {
          "name": "policy_evaluation",
          "abstraction": "quality_metric",
          "relations": [
            {"type": "estimates", "target": "value_function"},
            {"type": "precedes", "target": "policy_improvement"},
            {"type": "constrains", "target": "exploration"}
          ]
        },
        {
          "name": "entropy_regularization",
          "abstraction": "diversity_preservation",
          "relations": [
            {"type": "augments", "target": "exploration"},
            {"type": "constrains", "target": "deterministic_policy"},
            {"type": "requires", "target": "stochastic_policy"}
          ]
        },
        {
          "name": "reward_shaping",
          "abstraction": "guidance_signal",
          "relations": [
            {"type": "augments", "target": "exploitation"},
            {"type": "biases", "target": "expected_return"},
            {"type": "requires", "target": "domain_knowledge"}
          ]
        },
        {
          "name": "target_network",
          "abstraction": "stability_mechanism",
          "relations": [
            {"type": "stabilizes", "target": "policy_evaluation"},
            {"type": "delays", "target": "policy_improvement"},
            {"type": "constrains", "target": "update_speed"}
          ]
        },
        {
          "name": "experience_replay",
          "abstraction": "memory_buffer",
          "relations": [
            {"type": "stores", "target": "experience"},
            {"type": "decorrelates", "target": "gradient_updates"},
            {"type": "enables", "target": "off_policy_learning"}
          ]
        },
        {
          "name": "actor_critic",
          "abstraction": "dual_architecture",
          "relations": [
            {"type": "separates", "target": "exploration_from_evaluation"},
            {"type": "combines", "target": "policy_improvement_with_policy_evaluation"},
            {"type": "reduces", "target": "gradient_variance"}
          ]
        }
      ],
      "signature_cycles": [
        {"name": "explore_exploit_loop", "pattern": ["exploration", "exploitation", "policy_improvement"], "relation_chain": "precedes→precedes", "type": "cyclic_3node"},
        {"name": "actor_critic_separation", "pattern": ["actor_critic", "exploration", "exploitation"], "relation_chain": "separates→combines", "type": "architectural"},
        {"name": "target_network_stabilization", "pattern": ["target_network", "policy_evaluation", "policy_improvement"], "relation_chain": "stabilizes→delays", "type": "control"}
      ]
    },

    "causal_inference": {
      "name": "Causal Inference",
      "description": "Reasoning about cause-effect relationships beyond statistical association",
      "concepts": [
        {
          "name": "intervention",
          "abstraction": "controlled_variation",
          "relations": [
            {"type": "breaks", "target": "confounding"},
            {"type": "enables", "target": "causal_effect_estimation"},
            {"type": "requires", "target": "structural_causal_model"}
          ]
        },
        {
          "name": "counterfactual",
          "abstraction": "alternative_reality",
          "relations": [
            {"type": "contrasts", "target": "observed_outcome"},
            {"type": "requires", "target": "structural_causal_model"},
            {"type": "enables", "target": "individual_level_causation"}
          ]
        },
        {
          "name": "structural_causal_model",
          "abstraction": "causal_graph",
          "relations": [
            {"type": "encodes", "target": "causal_mechanisms"},
            {"type": "constrains", "target": "independence_relations"},
            {"type": "enables", "target": "do_calculus"}
          ]
        },
        {
          "name": "confounding",
          "abstraction": "hidden_common_cause",
          "relations": [
            {"type": "distorts", "target": "effect_estimation"},
            {"type": "motivates", "target": "intervention"},
            {"type": "violates", "target": "ignorability"}
          ]
        },
        {
          "name": "instrumental_variable",
          "abstraction": "exogenous_variation",
          "relations": [
            {"type": "bypasses", "target": "confounding"},
            {"type": "enables", "target": "causal_effect_estimation"},
            {"type": "requires", "target": "exclusion_restriction"}
          ]
        }
      ],
      "signature_cycles": [
        {"name": "intervention_counterfactual_pair", "pattern": ["intervention", "counterfactual"], "relation_chain": "contrasts→enables", "type": "complementary"},
        {"name": "causal_model_basis", "pattern": ["structural_causal_model", "intervention", "counterfactual"], "relation_chain": "enables→enables", "type": "hub"}
      ]
    },

    "control_theory": {
